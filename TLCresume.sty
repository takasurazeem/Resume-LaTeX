\NeedsTeXFormat{LaTeX2e}
\ProvidesPackage{TLCresume}[11/19/21 resume package]
% Author: Timmy Chan

% Assuming using "article" document class and letter-sized paper.
% FONT STUFF

\usepackage{fontspec} % Use custom fonts
\setmainfont{Times New Roman}

\RequirePackage[11pt]{moresize}
\usepackage{anyfontsize}
\RequirePackage{csquotes}

% MARGINS AND SPACING
\RequirePackage[margin=1in]{geometry}
\raggedright % left align no indent
\raggedbottom % top align no indent
\linespread{1.0} % Standard single line spacing

% COLOR
\RequirePackage{xcolor}

% LINKS
\RequirePackage{hyperref}
\hypersetup{colorlinks=true,urlcolor=black}

% BULLET POINTS
\RequirePackage[inline]{enumitem}
\setlength{\tabcolsep}{0in}

% SECTION FORMATTING 
\RequirePackage[nostruts]{titlesec}
\titlespacing*{\section}{0em}{1.0em}{0.3em}
\titleformat{\section}{\bfseries \raggedright}{}{0em}{\underline}
% SUBSECTION FORMATTING
\titlespacing*{\subsection}{0em}{0.4em}{0em} % Further adjusted spacing for subsections
\titleformat{\subsection}{\bfseries}{}{0em}{}[]

% BOLD COMMAND
\newcommand{\skills}[1]{ {\bfseries #1}}

% SUBTEXT
\newcommand{\subtext}[1]{\textit{#1}\par\vspace{-.4em}}

% standard spacing matching word documents
\setlist[itemize]{leftmargin=*}
\newenvironment{zitemize}{
\begin{itemize}}
{\end{itemize}\vspace{.1em}}

% NO PAGE NUMBER
\pagenumbering{gobble}

% SUBFILES IMPORTING
\RequirePackage{standalone}
\RequirePackage{import}

% FOR TEMPLATE FILLER
\RequirePackage[english]{babel}
\RequirePackage{blindtext}% Filler Text
